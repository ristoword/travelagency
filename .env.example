# =============================================
# TRAVEL AGENCY MANAGEMENT SYSTEM
# Variabili d'ambiente — copia in .env per sviluppo locale
# Su Railway: Settings → Variables → inserisci quelle contrassegnate con [RAILWAY]
# =============================================

# ── App ───────────────────────────────────────────────────
# [RAILWAY] Lascia vuoto — Railway inietta PORT automaticamente
# In locale usa 3000
APP_PORT=3000
NODE_ENV=development               # [RAILWAY] production

APP_NAME="Travel Agency Management System"
APP_URL=http://localhost:3000      # [RAILWAY] https://tuo-backend.railway.app
FRONTEND_URL=http://localhost:5173 # [RAILWAY] https://tuo-frontend.railway.app

# ── Database PostgreSQL ───────────────────────────────────
# [RAILWAY] Usa la sintassi template di Railway per referenziare il servizio Postgres:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
#
# In locale usa:
DATABASE_URL="postgresql://postgres:password@localhost:5432/travel_agency_db?schema=public"

# ── JWT ───────────────────────────────────────────────────
# [RAILWAY] Genera stringhe casuali lunghe almeno 32 caratteri
# Esempio generazione: openssl rand -base64 32
JWT_SECRET=cambia-questo-con-una-stringa-segreta-lunga-minimo-32-caratteri
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=cambia-questo-con-un-altra-stringa-segreta-lunga-minimo-32-caratteri
JWT_REFRESH_EXPIRES_IN=7d

# ── Rate Limiting ─────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── Redis ─────────────────────────────────────────────────
# [RAILWAY] Aggiungi un servizio Redis nel progetto Railway, poi usa:
# REDIS_URL=${{Redis.REDIS_URL}}
# oppure i singoli parametri:
REDIS_HOST=localhost               # [RAILWAY] ${{Redis.REDIS_HOST}}
REDIS_PORT=6379                    # [RAILWAY] ${{Redis.REDIS_PORT}}
REDIS_PASSWORD=                    # [RAILWAY] ${{Redis.REDIS_PASSWORD}}

# ── MinIO (File Storage) ──────────────────────────────────
# In produzione usa S3 o MinIO su Railway
MINIO_ENDPOINT=localhost           # [RAILWAY] endpoint del tuo MinIO
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin        # [RAILWAY] chiave accesso
MINIO_SECRET_KEY=minioadmin        # [RAILWAY] chiave segreta
MINIO_USE_SSL=false                # [RAILWAY] true
MINIO_BUCKET_NAME=travel-agency

# ── Elasticsearch ─────────────────────────────────────────
ELASTICSEARCH_NODE=http://localhost:9200  # [RAILWAY] URL del tuo Elasticsearch

# ── RabbitMQ ──────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672  # [RAILWAY] ${{RabbitMQ.AMQP_URL}}

# ── Email (SMTP) ──────────────────────────────────────────
# [RAILWAY] Usa SendGrid, Resend, Postmark o SMTP Gmail
SMTP_HOST=smtp.gmail.com           # [RAILWAY] smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=tua-email@gmail.com      # [RAILWAY] apikey (se SendGrid)
SMTP_PASS=tua-app-password         # [RAILWAY] SG.xxxxx (se SendGrid)
SMTP_FROM="Travel Agency <noreply@tua-agenzia.it>"

# ── WhatsApp Business API ─────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=          # [RAILWAY] ID numero WhatsApp Business
WHATSAPP_ACCESS_TOKEN=             # [RAILWAY] token Meta Business

# ── Stripe (Pagamenti) ────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...      # [RAILWAY] sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...    # [RAILWAY] whsec_...

# ── AWS S3 (alternativa a MinIO in produzione) ────────────
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=                 # [RAILWAY] chiave IAM
AWS_SECRET_ACCESS_KEY=             # [RAILWAY] secret IAM
AWS_S3_BUCKET=travel-agency-prod   # [RAILWAY] nome bucket S3

# ── Sentry (Error tracking) ───────────────────────────────
SENTRY_DSN=                        # [RAILWAY] DSN del progetto Sentry

# =============================================
# VARIABILI OBBLIGATORIE SU RAILWAY
# (minimo indispensabile per far partire il backend)
# =============================================
#
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# NODE_ENV=production
# JWT_SECRET=<stringa-random-32+caratteri>
# JWT_REFRESH_SECRET=<stringa-random-32+caratteri>
# JWT_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d
# APP_URL=https://tuo-backend.railway.app
# FRONTEND_URL=https://tuo-frontend.railway.app
