# =============================================================
# TRAVEL AGENCY MANAGEMENT SYSTEM — Backend (.env)
# Copia in .env per sviluppo locale
# Frontend admin: vedi apps/frontend-admin/.env.example
# =============================================================

# ── Application ───────────────────────────────────────────────
NODE_ENV=development
# [RAILWAY] production

APP_PORT=3000
# [RAILWAY] NON impostare PORT — Railway la inietta automaticamente

APP_NAME="Travel Agency Management System"
APP_URL=http://localhost:3000
# [RAILWAY] https://tuo-backend.railway.app

FRONTEND_URL=http://localhost:3001
# [RAILWAY] URL pubblico del servizio frontend-admin

# ── Database PostgreSQL ───────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/travel_agency_db?schema=public"
# [RAILWAY] postgresql://...@postgres.railway.internal:5432/railway

# ── JWT ───────────────────────────────────────────────────────
# Genera con: openssl rand -base64 32
JWT_SECRET=cambia-con-stringa-segreta-almeno-32-caratteri
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=cambia-con-altra-stringa-segreta-almeno-32-caratteri
JWT_REFRESH_EXPIRES_IN=7d

# ── Rate Limiting ─────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# [RAILWAY] usa REDIS_URL fornito dal plugin Redis

# ── MinIO (File Storage) ──────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=travel-agency

# ── Elasticsearch ─────────────────────────────────────────────
ELASTICSEARCH_NODE=http://localhost:9200

# ── RabbitMQ ──────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ── Email SMTP ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tua-email@gmail.com
SMTP_PASS=tua-app-password
SMTP_FROM="Travel Agency <noreply@travelagency.com>"

# ── WhatsApp Business ─────────────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── AWS S3 (alternativa a MinIO) ──────────────────────────────
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=travel-agency-prod

# ── Sentry ────────────────────────────────────────────────────
SENTRY_DSN=

# ── Bootstrap iniziale (nessun dato demo) ─────────────────────
# SuperAdmin — accesso pannello /superadmin (tenant: _superadmin)
SUPER_ADMIN_EMAIL=basilepaolo@me.com
SUPER_ADMIN_USERNAME=Mankikani
SUPER_ADMIN_PASSWORD=Be@trix1989P@1974zoe2026
SUPER_ADMIN_FORCE_PASSWORD_CHANGE=true

# Primo tenant agenzia (opzionale, solo bootstrap)
DEV_OWNER_ENABLED=true
DEV_OWNER_ALLOW_IN_PRODUCTION=false
DEV_OWNER_EMAIL=basilepaolo@me.com
DEV_OWNER_PASSWORD=Bimb@2015
DEV_OWNER_TENANT_SLUG=agenzia-principale
DEV_OWNER_TENANT_NAME="Agenzia Viaggi"

# =============================================================
# RAILWAY — BACKEND SERVICE
# Imposta le variabili sopra con valori di produzione.
# Obbligatori: DATABASE_URL, JWT_SECRET, JWT_REFRESH_SECRET,
# NODE_ENV=production, FRONTEND_URL (URL del frontend admin).
# =============================================================

# =============================================================
# RAILWAY — FRONTEND ADMIN (apps/frontend-admin/.env.example)
# Servizio separato, Dockerfile: apps/frontend-admin/Dockerfile
# Variabili: BACKEND_URL, NEXT_PUBLIC_* (vedi file dedicato)
# =============================================================
