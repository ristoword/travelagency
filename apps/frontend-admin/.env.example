# Frontend Admin — copia in apps/frontend-admin/.env (locale) o variabili Railway

# Proxy runtime verso il backend (preferito su Railway)
BACKEND_URL=http://localhost:3000

# Build-time (fallback se BACKEND_URL non impostato)
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Travel Agency Admin"
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=agenzia-principale

# Railway produzione:
# BACKEND_URL=https://travel-management-production.up.railway.app
# NEXT_PUBLIC_API_URL=https://travel-management-production.up.railway.app
# NEXT_PUBLIC_DEFAULT_TENANT_SLUG=agenzia-principale
# NEXT_PUBLIC_APP_NAME=Travel Agency Admin
