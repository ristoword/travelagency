# Frontend Admin — copia in apps/frontend-admin/.env (locale) o variabili Railway

# LOCALE
BACKEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Travel Agency Admin"
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=agenzia-principale

# =============================================================
# RAILWAY — SERVIZIO FRONTEND (apps/frontend-admin/Dockerfile)
# =============================================================
# IMPORTANTE: travel-management-production è il FRONTEND, NON il backend!
# Devi avere DUE servizi Railway:
#   1) Backend  → Dockerfile: apps/backend/Dockerfile (railway.toml root)
#   2) Frontend → Dockerfile: apps/frontend-admin/Dockerfile
#
# Sul servizio FRONTEND imposta (Variables → Deploy):
# BACKEND_URL=https://<URL-PUBBLICO-DEL-SERVIZIO-BACKEND>.up.railway.app
# NEXT_PUBLIC_DEFAULT_TENANT_SLUG=agenzia-principale
# NEXT_PUBLIC_APP_NAME=Travel Agency Admin
#
# NON usare localhost come BACKEND_URL in produzione!
# NON usare l'URL del frontend come BACKEND_URL!
#
# Verifica dopo deploy: https://<frontend>/api/debug-config
#   → backend.reachable deve essere true
