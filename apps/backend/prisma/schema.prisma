// =============================================================================
// TRAVEL AGENCY MANAGEMENT SYSTEM — PRISMA SCHEMA
// FASE 1: Foundation | FASE 2: CRM | FASE 3: Sales
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS — FASE 1
// =============================================================================

enum TenantPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PASSWORD_CHANGE
  PERMISSION_CHANGE
  EXPORT
  IMPORT
}

// =============================================================================
// ENUMS — FASE 2 CRM
// =============================================================================

enum ClientType {
  INDIVIDUAL
  COMPANY
  FAMILY
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

enum ClientSource {
  WALK_IN
  REFERRAL
  WEBSITE
  SOCIAL_MEDIA
  EMAIL_CAMPAIGN
  PHONE
  PARTNER
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  WON
  LOST
  ARCHIVED
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum LeadSource {
  WEBSITE
  SOCIAL_MEDIA
  REFERRAL
  WALK_IN
  EMAIL
  PHONE
  CAMPAIGN
  PARTNER
  OTHER
}

enum NoteType {
  GENERAL
  CALL
  EMAIL
  MEETING
  WHATSAPP
  INTERNAL
}

enum HistoryEventType {
  LEAD_CREATED
  LEAD_CONVERTED
  CLIENT_CREATED
  BOOKING_CREATED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  QUOTATION_SENT
  QUOTATION_ACCEPTED
  QUOTATION_REJECTED
  INVOICE_SENT
  PAYMENT_RECEIVED
  DOCUMENT_UPLOADED
  NOTE_ADDED
  CALL_LOGGED
  EMAIL_SENT
  MEETING_SCHEDULED
  COMPLAINT_FILED
  OTHER
}

enum TagType {
  CLIENT
  LEAD
  BOOKING
  GENERAL
}

// =============================================================================
// FASE 1: TENANTS
// =============================================================================

model Tenant {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  email       String?
  phone       String?
  address     String?
  city        String?
  country     String?    @default("IT")
  vatNumber   String?
  logoUrl     String?
  plan        TenantPlan @default(STARTER)
  isActive    Boolean    @default(true)
  trialEndsAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  users          User[]
  roles          Role[]
  auditLogs      AuditLog[]
  settings       TenantSetting[]
  clients         Client[]
  leads           Lead[]
  contacts        Contact[]
  tags            Tag[]
  customerNotes   CustomerNote[]
  customerHistory CustomerHistory[]
  opportunities   Opportunity[]
  quotations      Quotation[]
  proposals       Proposal[]

  @@map("tenants")
}

// =============================================================================
// FASE 1: USERS
// =============================================================================

model User {
  id                  String     @id @default(uuid())
  tenantId            String
  tenant              Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email               String
  password            String
  firstName           String
  lastName            String
  phone               String?
  avatarUrl           String?
  status              UserStatus @default(ACTIVE)
  isEmailVerified     Boolean    @default(false)
  emailVerifiedAt     DateTime?
  refreshToken        String?
  lastLoginAt         DateTime?
  lastLoginIp         String?
  passwordChangedAt   DateTime?
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  deletedAt           DateTime?

  userRoles            UserRole[]
  auditLogs            AuditLog[]
  assignedClients      Client[]        @relation("ClientAssignedTo")
  assignedLeads        Lead[]          @relation("LeadAssignedTo")
  customerNotes        CustomerNote[]
  assignedOpportunities Opportunity[]  @relation("OpportunityAssignedTo")
  assignedQuotations   Quotation[]     @relation("QuotationAssignedTo")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

// =============================================================================
// FASE 1: ROLES & PERMISSIONS
// =============================================================================

model Role {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid())
  resource    String
  action      String
  description String?

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model UserRole {
  userId     String
  roleId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())
  assignedBy String?

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// =============================================================================
// FASE 1: AUDIT LOG
// =============================================================================

model AuditLog {
  id         String      @id @default(uuid())
  tenantId   String
  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  userId     String?
  user       User?       @relation(fields: [userId], references: [id])
  action     AuditAction
  resource   String
  resourceId String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime    @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================================================
// FASE 1: TENANT SETTINGS
// =============================================================================

model TenantSetting {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("tenant_settings")
}

// =============================================================================
// FASE 2: CLIENTS
// =============================================================================

model Client {
  id                     String       @id @default(uuid())
  tenantId               String
  tenant                 Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type                   ClientType   @default(INDIVIDUAL)
  status                 ClientStatus @default(ACTIVE)
  source                 ClientSource @default(OTHER)

  // Personal / Company info
  firstName              String?
  lastName               String?
  companyName            String?
  taxCode                String?
  vatNumber              String?
  birthDate              DateTime?

  // Contact info
  email                  String?
  phone                  String?
  mobile                 String?
  website                String?

  // Address
  address                String?
  city                   String?
  province               String?
  postalCode             String?
  country                String?      @default("IT")

  // Preferences
  preferredLanguage      String?      @default("it")
  preferredCurrency      String?      @default("EUR")

  // Flags
  isVip                  Boolean      @default(false)
  isNewsletterSubscribed Boolean      @default(false)

  // Stats (denormalized for performance)
  totalBookings          Int          @default(0)
  totalSpent             Decimal      @default(0) @db.Decimal(12, 2)
  lastBookingDate        DateTime?

  // Internal
  assignedToId           String?
  assignedTo             User?        @relation("ClientAssignedTo", fields: [assignedToId], references: [id])
  internalNotes          String?

  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  deletedAt              DateTime?

  contacts               Contact[]
  notes                  CustomerNote[]
  preferences            CustomerPreference[]
  history                CustomerHistory[]
  tags                   ClientTag[]
  leads                  Lead[]
  opportunities          Opportunity[]
  quotations             Quotation[]

  @@index([tenantId])
  @@index([tenantId, email])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, isVip])
  @@map("clients")
}

// =============================================================================
// FASE 2: LEADS
// =============================================================================

model Lead {
  id             String       @id @default(uuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Basic info
  firstName      String
  lastName       String
  email          String?
  phone          String?
  mobile         String?

  // Lead classification
  status         LeadStatus   @default(NEW)
  priority       LeadPriority @default(MEDIUM)
  source         LeadSource   @default(OTHER)
  score          Int          @default(0)

  // Travel request
  destination    String?
  departureDate  DateTime?
  returnDate     DateTime?
  numberOfPeople Int?
  budget         Decimal?     @db.Decimal(10, 2)
  budgetCurrency String?      @default("EUR")
  travelType     String?
  description    String?

  // Assignment
  assignedToId   String?
  assignedTo     User?        @relation("LeadAssignedTo", fields: [assignedToId], references: [id])

  // Conversion
  clientId       String?
  client         Client?      @relation(fields: [clientId], references: [id])
  convertedAt    DateTime?
  lostReason     String?

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  notes          CustomerNote[]    @relation("LeadNotes")
  history        CustomerHistory[] @relation("LeadHistory")
  tags           LeadTag[]
  opportunities  Opportunity[]
  quotations     Quotation[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, priority])
  @@index([tenantId, assignedToId])
  @@map("leads")
}

// =============================================================================
// FASE 2: CONTACTS (linked to a Client)
// =============================================================================

model Contact {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  firstName   String
  lastName    String
  email       String?
  phone       String?
  mobile      String?
  role        String?   // e.g., "Coniuge", "Referente aziendale", "Figlio"
  birthDate   DateTime?
  taxCode     String?
  isPrimary   Boolean  @default(false)
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([tenantId])
  @@index([clientId])
  @@map("contacts")
}

// =============================================================================
// FASE 2: TAGS
// =============================================================================

model Tag {
  id       String  @id @default(uuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name     String
  color    String  @default("#6366f1")
  type     TagType @default(GENERAL)

  clientTags ClientTag[]
  leadTags   LeadTag[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("tags")
}

model ClientTag {
  clientId   String
  tagId      String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([clientId, tagId])
  @@map("client_tags")
}

model LeadTag {
  leadId     String
  tagId      String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([leadId, tagId])
  @@map("lead_tags")
}

// =============================================================================
// FASE 2: CUSTOMER NOTES
// =============================================================================

model CustomerNote {
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clientId   String?
  client     Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  leadId     String?
  lead       Lead?    @relation("LeadNotes", fields: [leadId], references: [id], onDelete: Cascade)

  authorId   String?
  author     User?    @relation(fields: [authorId], references: [id])

  type       NoteType @default(GENERAL)
  content    String
  isPrivate  Boolean  @default(false)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@index([clientId])
  @@index([leadId])
  @@map("customer_notes")
}

// =============================================================================
// FASE 2: CUSTOMER PREFERENCES
// =============================================================================

model CustomerPreference {
  id        String   @id @default(uuid())
  tenantId  String
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  key       String
  value     Json

  updatedAt DateTime @updatedAt

  @@unique([clientId, key])
  @@index([tenantId])
  @@index([clientId])
  @@map("customer_preferences")
}

// =============================================================================
// FASE 2: CUSTOMER HISTORY (timeline)
// =============================================================================

model CustomerHistory {
  id            String           @id @default(uuid())
  tenantId      String
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clientId      String?
  client        Client?          @relation(fields: [clientId], references: [id], onDelete: Cascade)

  leadId        String?
  lead          Lead?            @relation("LeadHistory", fields: [leadId], references: [id], onDelete: Cascade)

  eventType     HistoryEventType
  title         String
  description   String?
  referenceId   String?
  referenceType String?
  metadata      Json?
  eventDate     DateTime         @default(now())

  createdAt     DateTime         @default(now())

  @@index([tenantId])
  @@index([clientId])
  @@index([leadId])
  @@index([eventDate])
  @@map("customer_history")
}

// =============================================================================
// ENUMS — FASE 3 SALES
// =============================================================================

enum OpportunityStage {
  PROSPECTING
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum QuotationStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

enum QuotationItemType {
  FLIGHT
  HOTEL
  PACKAGE
  CRUISE
  TRAIN
  FERRY
  CAR_RENTAL
  TRANSFER
  EXCURSION
  INSURANCE
  VISA
  TICKET
  OTHER
}

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
}

// =============================================================================
// FASE 3: OPPORTUNITIES
// =============================================================================

model Opportunity {
  id                String           @id @default(uuid())
  tenantId          String
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clientId          String?
  client            Client?          @relation(fields: [clientId], references: [id])
  leadId            String?
  lead              Lead?            @relation(fields: [leadId], references: [id])

  title             String
  description       String?
  stage             OpportunityStage @default(PROSPECTING)
  probability       Int              @default(20)
  estimatedValue    Decimal?         @db.Decimal(12, 2)
  currency          String           @default("EUR")
  expectedCloseDate DateTime?

  assignedToId      String?
  assignedTo        User?            @relation("OpportunityAssignedTo", fields: [assignedToId], references: [id])

  lostReason        String?
  notes             String?

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?

  quotations        Quotation[]

  @@index([tenantId])
  @@index([tenantId, stage])
  @@index([tenantId, assignedToId])
  @@map("opportunities")
}

// =============================================================================
// FASE 3: QUOTATIONS (Preventivi)
// =============================================================================

model Quotation {
  id              String          @id @default(uuid())
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  number          String
  status          QuotationStatus @default(DRAFT)

  clientId        String?
  client          Client?         @relation(fields: [clientId], references: [id])
  leadId          String?
  lead            Lead?           @relation(fields: [leadId], references: [id])
  opportunityId   String?
  opportunity     Opportunity?    @relation(fields: [opportunityId], references: [id])

  // Travel details
  destination     String?
  departureDate   DateTime?
  returnDate      DateTime?
  numberOfPeople  Int?
  travelType      String?

  // Financial
  currency        String          @default("EUR")
  subtotal        Decimal         @default(0) @db.Decimal(12, 2)
  discountType    String?         // "percentage" | "fixed"
  discountValue   Decimal?        @db.Decimal(10, 2)
  discountAmount  Decimal         @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal         @default(0) @db.Decimal(12, 2)
  totalCost       Decimal         @default(0) @db.Decimal(12, 2)
  totalMargin     Decimal         @default(0) @db.Decimal(12, 2)
  marginPercent   Decimal         @default(0) @db.Decimal(5, 2)

  // Dates
  validUntil      DateTime?
  sentAt          DateTime?
  viewedAt        DateTime?
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  convertedAt     DateTime?

  // Content
  clientNotes     String?
  internalNotes   String?
  terms           String?

  assignedToId    String?
  assignedTo      User?           @relation("QuotationAssignedTo", fields: [assignedToId], references: [id])

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  items           QuotationItem[]
  proposal        Proposal?

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, clientId])
  @@index([tenantId, leadId])
  @@map("quotations")
}

// =============================================================================
// FASE 3: QUOTATION ITEMS
// =============================================================================

model QuotationItem {
  id                String            @id @default(uuid())
  quotationId       String
  quotation         Quotation         @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  tenantId          String

  type              QuotationItemType @default(OTHER)
  description       String
  details           String?
  quantity          Int               @default(1)
  unitPrice         Decimal           @db.Decimal(10, 2)
  totalPrice        Decimal           @db.Decimal(12, 2)
  supplierCost      Decimal           @default(0) @db.Decimal(10, 2)
  totalCost         Decimal           @default(0) @db.Decimal(12, 2)
  marginAmount      Decimal           @default(0) @db.Decimal(10, 2)
  marginPercent     Decimal           @default(0) @db.Decimal(5, 2)

  supplierId        String?
  supplierRef       String?
  notes             String?
  sortOrder         Int               @default(0)

  @@index([quotationId])
  @@index([tenantId])
  @@map("quotation_items")
}

// =============================================================================
// FASE 3: PROPOSALS
// =============================================================================

model Proposal {
  id          String         @id @default(uuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quotationId String         @unique
  quotation   Quotation      @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  title       String
  content     String
  status      ProposalStatus @default(DRAFT)
  sentAt      DateTime?
  viewedAt    DateTime?
  acceptedAt  DateTime?
  rejectedAt  DateTime?

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([tenantId])
  @@map("proposals")
}

// =============================================================================
// FASE 3: SEQUENCE COUNTER (for auto-numbering quotations)
// =============================================================================

model SequenceCounter {
  id        String   @id @default(uuid())
  tenantId  String
  type      String
  year      Int
  lastValue Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([tenantId, type, year])
  @@map("sequence_counters")
}
