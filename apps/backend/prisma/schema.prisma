// =============================================================================
// TRAVEL AGENCY MANAGEMENT SYSTEM — PRISMA SCHEMA
// FASE 1 | FASE 2: CRM | FASE 3: Sales | FASE 4: Travel Cases | FASE 5: Bookings | FASE 6: Accounting
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS — FASE 1
// =============================================================================

enum TenantPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PASSWORD_CHANGE
  PERMISSION_CHANGE
  EXPORT
  IMPORT
}

// =============================================================================
// ENUMS — FASE 2 CRM
// =============================================================================

enum ClientType {
  INDIVIDUAL
  COMPANY
  FAMILY
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

enum ClientSource {
  WALK_IN
  REFERRAL
  WEBSITE
  SOCIAL_MEDIA
  EMAIL_CAMPAIGN
  PHONE
  PARTNER
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  WON
  LOST
  ARCHIVED
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum LeadSource {
  WEBSITE
  SOCIAL_MEDIA
  REFERRAL
  WALK_IN
  EMAIL
  PHONE
  CAMPAIGN
  PARTNER
  OTHER
}

enum NoteType {
  GENERAL
  CALL
  EMAIL
  MEETING
  WHATSAPP
  INTERNAL
}

enum HistoryEventType {
  LEAD_CREATED
  LEAD_CONVERTED
  CLIENT_CREATED
  BOOKING_CREATED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  QUOTATION_SENT
  QUOTATION_ACCEPTED
  QUOTATION_REJECTED
  INVOICE_SENT
  PAYMENT_RECEIVED
  DOCUMENT_UPLOADED
  NOTE_ADDED
  CALL_LOGGED
  EMAIL_SENT
  MEETING_SCHEDULED
  COMPLAINT_FILED
  OTHER
}

enum TagType {
  CLIENT
  LEAD
  BOOKING
  GENERAL
}

// =============================================================================
// FASE 1: TENANTS
// =============================================================================

model Tenant {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  email       String?
  phone       String?
  address     String?
  city        String?
  country     String?    @default("IT")
  vatNumber   String?
  logoUrl     String?
  plan        TenantPlan @default(STARTER)
  isActive    Boolean    @default(true)
  trialEndsAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  users          User[]
  roles          Role[]
  auditLogs      AuditLog[]
  settings       TenantSetting[]
  clients         Client[]
  leads           Lead[]
  contacts        Contact[]
  tags            Tag[]
  customerNotes   CustomerNote[]
  customerHistory CustomerHistory[]
  opportunities   Opportunity[]
  quotations      Quotation[]
  proposals       Proposal[]
  travelCases     TravelCase[]
  bookings        Booking[]
  invoices        Invoice[]
  payments        Payment[]
  creditNotes     CreditNote[]

  @@map("tenants")
}

// =============================================================================
// FASE 1: USERS
// =============================================================================

model User {
  id                  String     @id @default(uuid())
  tenantId            String
  tenant              Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email               String
  password            String
  firstName           String
  lastName            String
  phone               String?
  avatarUrl           String?
  status              UserStatus @default(ACTIVE)
  isEmailVerified     Boolean    @default(false)
  emailVerifiedAt     DateTime?
  refreshToken        String?
  lastLoginAt         DateTime?
  lastLoginIp         String?
  passwordChangedAt   DateTime?
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  deletedAt           DateTime?

  userRoles            UserRole[]
  auditLogs            AuditLog[]
  assignedClients      Client[]        @relation("ClientAssignedTo")
  assignedLeads        Lead[]          @relation("LeadAssignedTo")
  customerNotes        CustomerNote[]
  assignedOpportunities Opportunity[]   @relation("OpportunityAssignedTo")
  assignedQuotations   Quotation[]      @relation("QuotationAssignedTo")
  assignedCases        TravelCase[]     @relation("CaseAssignedTo")
  caseNotes            CaseNote[]       @relation("CaseNoteAuthor")
  assignedBookings     Booking[]        @relation("BookingAssignedTo")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

// =============================================================================
// FASE 1: ROLES & PERMISSIONS
// =============================================================================

model Role {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid())
  resource    String
  action      String
  description String?

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model UserRole {
  userId     String
  roleId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())
  assignedBy String?

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// =============================================================================
// FASE 1: AUDIT LOG
// =============================================================================

model AuditLog {
  id         String      @id @default(uuid())
  tenantId   String
  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  userId     String?
  user       User?       @relation(fields: [userId], references: [id])
  action     AuditAction
  resource   String
  resourceId String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime    @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================================================
// FASE 1: TENANT SETTINGS
// =============================================================================

model TenantSetting {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("tenant_settings")
}

// =============================================================================
// FASE 2: CLIENTS
// =============================================================================

model Client {
  id                     String       @id @default(uuid())
  tenantId               String
  tenant                 Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type                   ClientType   @default(INDIVIDUAL)
  status                 ClientStatus @default(ACTIVE)
  source                 ClientSource @default(OTHER)

  // Personal / Company info
  firstName              String?
  lastName               String?
  companyName            String?
  taxCode                String?
  vatNumber              String?
  birthDate              DateTime?

  // Contact info
  email                  String?
  phone                  String?
  mobile                 String?
  website                String?

  // Address
  address                String?
  city                   String?
  province               String?
  postalCode             String?
  country                String?      @default("IT")

  // Preferences
  preferredLanguage      String?      @default("it")
  preferredCurrency      String?      @default("EUR")

  // Flags
  isVip                  Boolean      @default(false)
  isNewsletterSubscribed Boolean      @default(false)

  // Stats (denormalized for performance)
  totalBookings          Int          @default(0)
  totalSpent             Decimal      @default(0) @db.Decimal(12, 2)
  lastBookingDate        DateTime?

  // Internal
  assignedToId           String?
  assignedTo             User?        @relation("ClientAssignedTo", fields: [assignedToId], references: [id])
  internalNotes          String?

  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  deletedAt              DateTime?

  contacts               Contact[]
  notes                  CustomerNote[]
  preferences            CustomerPreference[]
  history                CustomerHistory[]
  tags                   ClientTag[]
  leads                  Lead[]
  opportunities          Opportunity[]
  quotations             Quotation[]
  travelCases            TravelCase[]
  bookings               Booking[]        @relation("BookingClient")
  invoices               Invoice[]        @relation("InvoiceClient")
  payments               Payment[]        @relation("PaymentClient")
  creditNotes            CreditNote[]     @relation("CreditNoteClient")

  @@index([tenantId])
  @@index([tenantId, email])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, isVip])
  @@map("clients")
}

// =============================================================================
// FASE 2: LEADS
// =============================================================================

model Lead {
  id             String       @id @default(uuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Basic info
  firstName      String
  lastName       String
  email          String?
  phone          String?
  mobile         String?

  // Lead classification
  status         LeadStatus   @default(NEW)
  priority       LeadPriority @default(MEDIUM)
  source         LeadSource   @default(OTHER)
  score          Int          @default(0)

  // Travel request
  destination    String?
  departureDate  DateTime?
  returnDate     DateTime?
  numberOfPeople Int?
  budget         Decimal?     @db.Decimal(10, 2)
  budgetCurrency String?      @default("EUR")
  travelType     String?
  description    String?

  // Assignment
  assignedToId   String?
  assignedTo     User?        @relation("LeadAssignedTo", fields: [assignedToId], references: [id])

  // Conversion
  clientId       String?
  client         Client?      @relation(fields: [clientId], references: [id])
  convertedAt    DateTime?
  lostReason     String?

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  notes          CustomerNote[]    @relation("LeadNotes")
  history        CustomerHistory[] @relation("LeadHistory")
  tags           LeadTag[]
  opportunities  Opportunity[]
  quotations     Quotation[]
  travelCases    TravelCase[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, priority])
  @@index([tenantId, assignedToId])
  @@map("leads")
}

// =============================================================================
// FASE 2: CONTACTS (linked to a Client)
// =============================================================================

model Contact {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  firstName   String
  lastName    String
  email       String?
  phone       String?
  mobile      String?
  role        String?   // e.g., "Coniuge", "Referente aziendale", "Figlio"
  birthDate   DateTime?
  taxCode     String?
  isPrimary   Boolean  @default(false)
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([tenantId])
  @@index([clientId])
  @@map("contacts")
}

// =============================================================================
// FASE 2: TAGS
// =============================================================================

model Tag {
  id       String  @id @default(uuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name     String
  color    String  @default("#6366f1")
  type     TagType @default(GENERAL)

  clientTags ClientTag[]
  leadTags   LeadTag[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("tags")
}

model ClientTag {
  clientId   String
  tagId      String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([clientId, tagId])
  @@map("client_tags")
}

model LeadTag {
  leadId     String
  tagId      String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([leadId, tagId])
  @@map("lead_tags")
}

// =============================================================================
// FASE 2: CUSTOMER NOTES
// =============================================================================

model CustomerNote {
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clientId   String?
  client     Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  leadId     String?
  lead       Lead?    @relation("LeadNotes", fields: [leadId], references: [id], onDelete: Cascade)

  authorId   String?
  author     User?    @relation(fields: [authorId], references: [id])

  type       NoteType @default(GENERAL)
  content    String
  isPrivate  Boolean  @default(false)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@index([clientId])
  @@index([leadId])
  @@map("customer_notes")
}

// =============================================================================
// FASE 2: CUSTOMER PREFERENCES
// =============================================================================

model CustomerPreference {
  id        String   @id @default(uuid())
  tenantId  String
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  key       String
  value     Json

  updatedAt DateTime @updatedAt

  @@unique([clientId, key])
  @@index([tenantId])
  @@index([clientId])
  @@map("customer_preferences")
}

// =============================================================================
// FASE 2: CUSTOMER HISTORY (timeline)
// =============================================================================

model CustomerHistory {
  id            String           @id @default(uuid())
  tenantId      String
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clientId      String?
  client        Client?          @relation(fields: [clientId], references: [id], onDelete: Cascade)

  leadId        String?
  lead          Lead?            @relation("LeadHistory", fields: [leadId], references: [id], onDelete: Cascade)

  eventType     HistoryEventType
  title         String
  description   String?
  referenceId   String?
  referenceType String?
  metadata      Json?
  eventDate     DateTime         @default(now())

  createdAt     DateTime         @default(now())

  @@index([tenantId])
  @@index([clientId])
  @@index([leadId])
  @@index([eventDate])
  @@map("customer_history")
}

// =============================================================================
// ENUMS — FASE 3 SALES
// =============================================================================

enum OpportunityStage {
  PROSPECTING
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum QuotationStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

enum QuotationItemType {
  FLIGHT
  HOTEL
  PACKAGE
  CRUISE
  TRAIN
  FERRY
  CAR_RENTAL
  TRANSFER
  EXCURSION
  INSURANCE
  VISA
  TICKET
  OTHER
}

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
}

// =============================================================================
// FASE 3: OPPORTUNITIES
// =============================================================================

model Opportunity {
  id                String           @id @default(uuid())
  tenantId          String
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clientId          String?
  client            Client?          @relation(fields: [clientId], references: [id])
  leadId            String?
  lead              Lead?            @relation(fields: [leadId], references: [id])

  title             String
  description       String?
  stage             OpportunityStage @default(PROSPECTING)
  probability       Int              @default(20)
  estimatedValue    Decimal?         @db.Decimal(12, 2)
  currency          String           @default("EUR")
  expectedCloseDate DateTime?

  assignedToId      String?
  assignedTo        User?            @relation("OpportunityAssignedTo", fields: [assignedToId], references: [id])

  lostReason        String?
  notes             String?

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?

  quotations        Quotation[]

  @@index([tenantId])
  @@index([tenantId, stage])
  @@index([tenantId, assignedToId])
  @@map("opportunities")
}

// =============================================================================
// FASE 3: QUOTATIONS (Preventivi)
// =============================================================================

model Quotation {
  id              String          @id @default(uuid())
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  number          String
  status          QuotationStatus @default(DRAFT)

  clientId        String?
  client          Client?         @relation(fields: [clientId], references: [id])
  leadId          String?
  lead            Lead?           @relation(fields: [leadId], references: [id])
  opportunityId   String?
  opportunity     Opportunity?    @relation(fields: [opportunityId], references: [id])

  // Travel details
  destination     String?
  departureDate   DateTime?
  returnDate      DateTime?
  numberOfPeople  Int?
  travelType      String?

  // Financial
  currency        String          @default("EUR")
  subtotal        Decimal         @default(0) @db.Decimal(12, 2)
  discountType    String?         // "percentage" | "fixed"
  discountValue   Decimal?        @db.Decimal(10, 2)
  discountAmount  Decimal         @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal         @default(0) @db.Decimal(12, 2)
  totalCost       Decimal         @default(0) @db.Decimal(12, 2)
  totalMargin     Decimal         @default(0) @db.Decimal(12, 2)
  marginPercent   Decimal         @default(0) @db.Decimal(5, 2)

  // Dates
  validUntil      DateTime?
  sentAt          DateTime?
  viewedAt        DateTime?
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  convertedAt     DateTime?

  // Content
  clientNotes     String?
  internalNotes   String?
  terms           String?

  assignedToId    String?
  assignedTo      User?           @relation("QuotationAssignedTo", fields: [assignedToId], references: [id])

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  items           QuotationItem[]
  proposal        Proposal?
  travelCase      TravelCase?

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, clientId])
  @@index([tenantId, leadId])
  @@map("quotations")
}

// =============================================================================
// FASE 3: QUOTATION ITEMS
// =============================================================================

model QuotationItem {
  id                String            @id @default(uuid())
  quotationId       String
  quotation         Quotation         @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  tenantId          String

  type              QuotationItemType @default(OTHER)
  description       String
  details           String?
  quantity          Int               @default(1)
  unitPrice         Decimal           @db.Decimal(10, 2)
  totalPrice        Decimal           @db.Decimal(12, 2)
  supplierCost      Decimal           @default(0) @db.Decimal(10, 2)
  totalCost         Decimal           @default(0) @db.Decimal(12, 2)
  marginAmount      Decimal           @default(0) @db.Decimal(10, 2)
  marginPercent     Decimal           @default(0) @db.Decimal(5, 2)

  supplierId        String?
  supplierRef       String?
  notes             String?
  sortOrder         Int               @default(0)

  @@index([quotationId])
  @@index([tenantId])
  @@map("quotation_items")
}

// =============================================================================
// FASE 3: PROPOSALS
// =============================================================================

model Proposal {
  id          String         @id @default(uuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quotationId String         @unique
  quotation   Quotation      @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  title       String
  content     String
  status      ProposalStatus @default(DRAFT)
  sentAt      DateTime?
  viewedAt    DateTime?
  acceptedAt  DateTime?
  rejectedAt  DateTime?

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([tenantId])
  @@map("proposals")
}

// =============================================================================
// FASE 3: SEQUENCE COUNTER (for auto-numbering quotations)
// =============================================================================

model SequenceCounter {
  id        String   @id @default(uuid())
  tenantId  String
  type      String
  year      Int
  lastValue Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([tenantId, type, year])
  @@map("sequence_counters")
}

// =============================================================================
// ENUMS — FASE 4 TRAVEL CASES
// =============================================================================

enum CaseStatus {
  INQUIRY
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REFUNDED
}

enum CaseServiceStatus {
  PENDING
  CONFIRMED
  CANCELLED
  ON_REQUEST
}

enum CaseServiceType {
  FLIGHT
  HOTEL
  PACKAGE
  CRUISE
  TRAIN
  FERRY
  CAR_RENTAL
  TRANSFER
  EXCURSION
  INSURANCE
  VISA
  TICKET
  OTHER
}

// =============================================================================
// FASE 4: TRAVEL CASES (Pratiche)
// =============================================================================

model TravelCase {
  id              String     @id @default(uuid())
  tenantId        String
  tenant          Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  number          String
  title           String
  status          CaseStatus @default(INQUIRY)
  description     String?

  // Links
  clientId        String?
  client          Client?    @relation(fields: [clientId], references: [id])
  leadId          String?
  lead            Lead?      @relation(fields: [leadId], references: [id])
  quotationId     String?    @unique
  quotation       Quotation? @relation(fields: [quotationId], references: [id])

  // Travel details
  destination     String?
  departureDate   DateTime?
  returnDate      DateTime?
  numberOfPeople  Int?
  travelType      String?

  // Financial
  currency        String     @default("EUR")
  totalAmount     Decimal    @default(0) @db.Decimal(12, 2)
  totalCost       Decimal    @default(0) @db.Decimal(12, 2)
  totalPaid       Decimal    @default(0) @db.Decimal(12, 2)
  balance         Decimal    @default(0) @db.Decimal(12, 2)

  // Internal
  assignedToId    String?
  assignedTo      User?      @relation("CaseAssignedTo", fields: [assignedToId], references: [id])
  internalNotes   String?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  passengers      Passenger[]
  itinerary       CaseItinerary[]
  services        CaseService[]
  checklists      CaseChecklist[]
  statusHistory   CaseStatusHistory[]
  notes           CaseNote[]
  bookings        Booking[]
  invoices        Invoice[]            @relation("InvoiceCase")

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, clientId])
  @@map("travel_cases")
}

// =============================================================================
// FASE 4: PASSENGERS
// =============================================================================

model Passenger {
  id               String     @id @default(uuid())
  tenantId         String
  caseId           String
  case             TravelCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  contactId        String?

  firstName        String
  lastName         String
  birthDate        DateTime?
  nationality      String?    @default("IT")
  taxCode          String?

  // Document
  passportNumber   String?
  passportExpiry   DateTime?
  passportIssuedBy String?

  // Contact
  email            String?
  phone            String?

  // Preferences
  isLeader         Boolean    @default(false)
  mealPreference   String?
  seatPreference   String?
  specialNeeds     String?
  notes            String?

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([caseId])
  @@index([tenantId])
  @@map("passengers")
}

// =============================================================================
// FASE 4: ITINERARY
// =============================================================================

model CaseItinerary {
  id            String     @id @default(uuid())
  tenantId      String
  caseId        String
  case          TravelCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  dayNumber     Int
  date          DateTime?
  title         String
  description   String?
  location      String?
  accommodation String?
  breakfast     Boolean    @default(false)
  lunch         Boolean    @default(false)
  dinner        Boolean    @default(false)
  notes         String?

  @@index([caseId])
  @@index([tenantId])
  @@map("case_itinerary")
}

// =============================================================================
// FASE 4: CASE SERVICES (booked services)
// =============================================================================

model CaseService {
  id              String            @id @default(uuid())
  tenantId        String
  caseId          String
  case            TravelCase        @relation(fields: [caseId], references: [id], onDelete: Cascade)

  type            CaseServiceType   @default(OTHER)
  description     String
  provider        String?
  providerRef     String?
  status          CaseServiceStatus @default(PENDING)

  serviceDate     DateTime?
  serviceEndDate  DateTime?
  amount          Decimal           @default(0) @db.Decimal(10, 2)
  cost            Decimal           @default(0) @db.Decimal(10, 2)
  currency        String            @default("EUR")

  numberOfPax     Int?
  notes           String?
  confirmationDoc String?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([caseId])
  @@index([tenantId])
  @@map("case_services")
}

// =============================================================================
// FASE 4: CHECKLISTS
// =============================================================================

model CaseChecklist {
  id            String     @id @default(uuid())
  tenantId      String
  caseId        String
  case          TravelCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  item          String
  isCompleted   Boolean    @default(false)
  completedAt   DateTime?
  completedById String?
  dueDate       DateTime?
  assignedToId  String?
  notes         String?

  createdAt     DateTime   @default(now())

  @@index([caseId])
  @@map("case_checklists")
}

// =============================================================================
// FASE 4: STATUS HISTORY
// =============================================================================

model CaseStatusHistory {
  id          String     @id @default(uuid())
  tenantId    String
  caseId      String
  case        TravelCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  fromStatus  CaseStatus?
  toStatus    CaseStatus
  notes       String?
  changedById String?
  changedAt   DateTime   @default(now())

  @@index([caseId])
  @@map("case_status_history")
}

// =============================================================================
// FASE 4: CASE NOTES
// =============================================================================

model CaseNote {
  id        String     @id @default(uuid())
  tenantId  String
  caseId    String
  case      TravelCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?      @relation("CaseNoteAuthor", fields: [authorId], references: [id])
  type      NoteType   @default(GENERAL)
  content   String
  isPrivate Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([caseId])
  @@index([tenantId])
  @@map("case_notes")
}

// =============================================================================
// ENUMS — FASE 5 BOOKINGS
// =============================================================================

enum BookingType {
  FLIGHT
  HOTEL
  PACKAGE
  CRUISE
  TRAIN
  FERRY
  CAR_RENTAL
  TRANSFER
  EXCURSION
  INSURANCE
  VISA
  TICKET
  OTHER
}

enum BookingStatus {
  ON_REQUEST
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
  NO_SHOW
}

enum DocumentType {
  VOUCHER
  TICKET
  CONFIRMATION
  INVOICE
  RECEIPT
  OTHER
}

// =============================================================================
// FASE 5: BOOKINGS
// Unified model — `details` JSON holds type-specific fields
// (flight: from/to/flightNo/class; hotel: roomType/checkIn/checkOut; etc.)
// =============================================================================

model Booking {
  id                String        @id @default(uuid())
  tenantId          String
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  number            String
  type              BookingType
  status            BookingStatus @default(PENDING)
  description       String

  // Links
  caseId            String?
  case              TravelCase?   @relation(fields: [caseId], references: [id])
  clientId          String?
  client            Client?       @relation("BookingClient", fields: [clientId], references: [id])

  // Supplier
  supplierName      String?
  supplierRef       String?
  providerRef       String?
  confirmationCode  String?

  // Dates
  serviceDate       DateTime?
  serviceEndDate    DateTime?

  // Financial
  currency          String        @default("EUR")
  amount            Decimal       @default(0) @db.Decimal(10, 2)
  cost              Decimal       @default(0) @db.Decimal(10, 2)
  commissionRate    Decimal?      @db.Decimal(5, 2)
  commissionAmount  Decimal       @default(0) @db.Decimal(10, 2)
  marginAmount      Decimal       @default(0) @db.Decimal(10, 2)
  marginPercent     Decimal       @default(0) @db.Decimal(5, 2)
  isPaidToSupplier  Boolean       @default(false)
  paidToSupplierAt  DateTime?

  // Pax
  numberOfPax       Int?

  // Type-specific details (JSON)
  // FLIGHT:   { from, to, airline, flightNumber, departure, arrival, class, pnr }
  // HOTEL:    { hotelName, roomType, checkIn, checkOut, nights, mealPlan, board }
  // TRANSFER: { from, to, vehicle, pickupTime, driverContact }
  // CRUISE:   { shipName, company, cabin, embarkation, disembarkation }
  // CAR:      { company, category, pickupLocation, dropoffLocation }
  // VISA:     { country, type, processingTime, validity }
  details           Json?

  notes             String?
  internalNotes     String?
  cancelledAt       DateTime?
  cancelReason      String?

  assignedToId      String?
  assignedTo        User?         @relation("BookingAssignedTo", fields: [assignedToId], references: [id])

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?

  documents         BookingDocument[]
  passengers        BookingPassenger[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, status])
  @@index([tenantId, caseId])
  @@index([tenantId, clientId])
  @@map("bookings")
}

// =============================================================================
// FASE 5: BOOKING PASSENGERS
// =============================================================================

model BookingPassenger {
  id          String   @id @default(uuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  passengerId String?

  firstName   String
  lastName    String
  notes       String?

  @@index([bookingId])
  @@map("booking_passengers")
}

// =============================================================================
// FASE 5: BOOKING DOCUMENTS
// =============================================================================

model BookingDocument {
  id          String       @id @default(uuid())
  tenantId    String
  bookingId   String
  booking     Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  type        DocumentType @default(VOUCHER)
  name        String
  fileUrl     String?
  fileKey     String?
  mimeType    String?
  sizeBytes   Int?
  notes       String?

  uploadedById String?
  createdAt   DateTime     @default(now())

  @@index([bookingId])
  @@index([tenantId])
  @@map("booking_documents")
}

// =============================================================================
// ENUMS — FASE 6 ACCOUNTING
// =============================================================================

enum InvoiceType {
  INVOICE
  PROFORMA
  RECEIPT
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CREDIT_CARD
  DEBIT_CARD
  CHECK
  STRIPE
  PAYPAL
  POS
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentDirection {
  INCOMING
  OUTGOING
}

enum CreditNoteStatus {
  DRAFT
  ISSUED
  APPLIED
  CANCELLED
}

// =============================================================================
// FASE 6: INVOICES
// =============================================================================

model Invoice {
  id             String        @id @default(uuid())
  tenantId       String
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  number         String
  type           InvoiceType   @default(INVOICE)
  status         InvoiceStatus @default(DRAFT)

  // Links
  clientId       String?
  client         Client?       @relation("InvoiceClient", fields: [clientId], references: [id])
  caseId         String?
  case           TravelCase?   @relation("InvoiceCase", fields: [caseId], references: [id])
  bookingId      String?

  // Dates
  issuedAt       DateTime?
  dueDate        DateTime?
  sentAt         DateTime?
  paidAt         DateTime?

  // Financial
  currency       String        @default("EUR")
  subtotal       Decimal       @default(0) @db.Decimal(12, 2)
  discountAmount Decimal       @default(0) @db.Decimal(10, 2)
  vatRate        Decimal       @default(22) @db.Decimal(5, 2)
  vatAmount      Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal       @default(0) @db.Decimal(12, 2)
  paidAmount     Decimal       @default(0) @db.Decimal(12, 2)
  balanceDue     Decimal       @default(0) @db.Decimal(12, 2)

  // Client details (snapshot at invoice time)
  clientName     String?
  clientAddress  String?
  clientVat      String?
  clientTaxCode  String?

  // Tenant details
  tenantName     String?
  tenantVat      String?

  notes          String?
  internalNotes  String?
  paymentTerms   String?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  items          InvoiceItem[]
  payments       Payment[]
  creditNotes    CreditNote[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, clientId])
  @@index([dueDate])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenantId    String

  description String
  quantity    Decimal @default(1) @db.Decimal(10, 3)
  unitPrice   Decimal @db.Decimal(10, 2)
  amount      Decimal @db.Decimal(12, 2)
  vatRate     Decimal @default(22) @db.Decimal(5, 2)
  vatAmount   Decimal @default(0) @db.Decimal(10, 2)
  total       Decimal @db.Decimal(12, 2)
  sortOrder   Int     @default(0)

  @@index([invoiceId])
  @@map("invoice_items")
}

// =============================================================================
// FASE 6: PAYMENTS
// =============================================================================

model Payment {
  id          String           @id @default(uuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  invoiceId   String?
  invoice     Invoice?         @relation(fields: [invoiceId], references: [id])
  clientId    String?
  client      Client?          @relation("PaymentClient", fields: [clientId], references: [id])
  caseId      String?

  direction   PaymentDirection @default(INCOMING)
  method      PaymentMethod    @default(BANK_TRANSFER)
  status      PaymentStatus    @default(PENDING)

  amount      Decimal          @db.Decimal(12, 2)
  currency    String           @default("EUR")
  reference   String?
  notes       String?

  paidAt      DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([tenantId])
  @@index([tenantId, invoiceId])
  @@index([tenantId, clientId])
  @@index([tenantId, status])
  @@index([paidAt])
  @@map("payments")
}

// =============================================================================
// FASE 6: CREDIT NOTES
// =============================================================================

model CreditNote {
  id          String           @id @default(uuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  number      String
  status      CreditNoteStatus @default(DRAFT)
  invoiceId   String?
  invoice     Invoice?         @relation(fields: [invoiceId], references: [id])
  clientId    String?
  client      Client?          @relation("CreditNoteClient", fields: [clientId], references: [id])

  reason      String
  amount      Decimal          @db.Decimal(12, 2)
  vatAmount   Decimal          @default(0) @db.Decimal(10, 2)
  totalAmount Decimal          @db.Decimal(12, 2)
  currency    String           @default("EUR")

  issuedAt    DateTime?
  appliedAt   DateTime?
  notes       String?

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, invoiceId])
  @@map("credit_notes")
}
